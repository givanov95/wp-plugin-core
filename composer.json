{
    "name": "givanov95/wp-plugin-core",
    "description": "Core PHP toolkit for building WordPress plugins: service providers, Vite asset integration, REST helpers, admin menus, validation, and a thin DB layer.",
    "type": "library",
    "license": "MIT",
    "keywords": ["wordpress", "wordpress-plugin", "vite", "rest-api", "service-provider"],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.9",
        "symfony/var-dumper": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "WpPluginCore\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Georgi Ivanov",
            "email": "joroz95@gmail.com"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
